# Docker Compose environment variables
# Copy this file to .env in the project root for docker-compose to pick it up.
# NOTE: docker-compose reads .env from the project root, NOT from backend/.env

POSTGRES_USER=CHANGEME
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=nstp_db

# Backend variables (also required in backend/.env for local dev)
JWT_SECRET=CHANGEME
JWT_EXPIRES_IN=24h
ADMIN_EMAIL=CHANGEME
ADMIN_PASSWORD=CHANGEME
