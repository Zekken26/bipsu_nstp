# Docker Compose environment variables
# Copy this file to .env in the project root for docker-compose to pick it up.
# NOTE: docker-compose reads .env from the project root, NOT from backend/.env

POSTGRES_USER=nstp
POSTGRES_PASSWORD=nstp_secret
POSTGRES_DB=nstp_db

# Backend variables (also required in backend/.env for local dev)
JWT_SECRET=change_this_to_a_secure_random_secret
JWT_EXPIRES_IN=24h
ADMIN_EMAIL=admin@bipsu.edu.ph
ADMIN_PASSWORD=admin2026
